{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rootDirectory": "apps/admin",
  "buildCommand": "cd ../.. && npx prisma generate --schema=./prisma/schema.prisma && SKIP_ENV_VALIDATION=true npx turbo run build --filter=@rentalshop/admin",
  "devCommand": "yarn workspace @rentalshop/admin dev",
  "installCommand": "cd ../.. && yarn install",
  "framework": "nextjs",
  "rewrites": [],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
