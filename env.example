# ========================================
# RAILWAY ENVIRONMENT VARIABLES
# ========================================
# Environment variables for Railway deployment
# Copy these to Railway Dashboard or use setup script: ./scripts/setup-railway-env.sh
#
# QUICK REFERENCE:
#   📦 API Service:    Requires all variables below (11 required + optional AWS S3)
#   🎛️  Admin Service:  Requires NODE_ENV, NEXTAUTH_SECRET, NEXTAUTH_URL, NEXT_PUBLIC_API_URL
#   🛒 Client Service: Requires NODE_ENV, NEXTAUTH_SECRET, NEXTAUTH_URL, NEXT_PUBLIC_API_URL
#
# IMPORTANT: NEXTAUTH_SECRET must be the SAME across all 3 services!
#
# See RAILWAY_ENV_VARIABLES_GUIDE.md for detailed explanation
# See RAILWAY_ENV_MINIMAL.md for quick summary

# ========================================
# DATABASE CONFIGURATION
# ========================================
# PostgreSQL database from Railway
# Use variable reference to connect to Railway PostgreSQL service
DATABASE_URL=${{Postgres.DATABASE_URL}}

# ========================================
# NODE ENVIRONMENT
# ========================================
NODE_ENV=production

# ========================================
# QDRANT COLLECTION ENVIRONMENT (OPTIONAL)
# ========================================
# Use this to override NODE_ENV for Qdrant collection selection
# Set to "development" for dev server, "production" for prod server
# If not set, will fallback to APP_ENV, then NODE_ENV
# QDRANT_COLLECTION_ENV=development

# ========================================
# JWT CONFIGURATION (CRITICAL - Set Strong Secrets!)
# ========================================
# Generate with: openssl rand -hex 32
# Must be at least 32 characters
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
JWT_EXPIRES_IN=1d

# ========================================
# NEXTAUTH CONFIGURATION (CRITICAL - Set Strong Secrets!)
# ========================================
# Generate with: openssl rand -hex 32
# Must be at least 32 characters
# Use same NEXTAUTH_SECRET across all services (api, admin, client)
NEXTAUTH_SECRET=your-super-secret-nextauth-key-minimum-32-characters

# Set to your actual deployment URL or custom domain
NEXTAUTH_URL=https://api.anyrent.shop

# ========================================
# API URLS (Development and Production)
# ========================================
# Development API
API_URL=https://dev-api.anyrent.shop

# Production API  
API_URL_PROD=https://api.anyrent.shop

# Development Client & Admin
CLIENT_URL=https://dev.anyrent.shop

ADMIN_URL=https://dev-admin.anyrent.shop

# Production Client & Admin
CLIENT_URL_PROD=https://anyrent.shop
ADMIN_URL_PROD=https://admin.anyrent.shop

# Public API URL for client-side requests (must start with NEXT_PUBLIC_)
# Development
NEXT_PUBLIC_API_URL=https://dev-api.anyrent.shop
# Production: NEXT_PUBLIC_API_URL=https://api.anyrent.shop

# ========================================
# CORS CONFIGURATION
# ========================================
# Comma-separated list of allowed origins (no trailing slashes, no spaces)
# Development
CORS_ORIGINS=https://dev.anyrent.shop,https://dev-admin.anyrent.shop
# Production: CORS_ORIGINS=https://anyrent.shop,https://admin.anyrent.shop

# NOTE: Admin app is deployed on both Railway and Vercel
# Railway Admin:
# - Production: https://admin.anyrent.shop (Railway)
# - Development: https://dev-admin.anyrent.shop (Railway)
# Vercel Admin:
# - Production: https://adminvercel.anyrent.shop (Vercel)
# - Development: https://dev-adminvercel.anyrent.shop (Vercel)
# All four domains must be included in Railway API CORS_ORIGINS

# ========================================
# LOGGING CONFIGURATION (Optional)
# ========================================
# Log level: debug, info, warn, error
# Default: info (production), debug (development)
LOG_LEVEL=info

# Axiom Cloud Logging (Optional - Free tier: 500GB/month)
# Sign up at https://axiom.co (free, no credit card required)
# Get token from: Settings → API Tokens → Create Token
# Get org ID from: Settings → Organization
AXIOM_TOKEN=xaat-32bf74a4-0151-48da-85b7-d5e13c1afe22
AXIOM_ORG_ID=CEFConsultant

# Dataset Configuration (Auto-selected by environment if not set)
# If AXIOM_DATASET is not set, logger will auto-select:
#   - Development: rentalshop-logs-dev
#   - Production: rentalshop-logs-prod
# To use same dataset for both, set explicitly:
# AXIOM_DATASET=rentalshop-logs
# Or use separate datasets (recommended):
# Development: AXIOM_DATASET=rentalshop-logs-dev
# Production: AXIOM_DATASET=rentalshop-logs-prod
AXIOM_DATASET=

# Log level for Axiom (info, warn, error)
# Development: Use 'info' to see all logs
# Production: Use 'warn' to save quota (only warnings and errors)
AXIOM_LOG_LEVEL=info

# ========================================
# FILE UPLOAD - AWS S3 (Primary) + Railway Volume (Fallback)
# ========================================
# Primary: AWS S3 for CDN and scalability
# Fallback: Railway Volume for reliability

# AWS S3 Configuration (Primary)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# Bucket name: auto-selected based on NODE_ENV
# - Development: anyrent-images-dev
# - Production: anyrent-images-pro
# Or set explicitly: AWS_S3_BUCKET_NAME=anyrent-images-dev
AWS_S3_BUCKET_NAME=
# CloudFront custom domain (e.g., images.anyrent.shop) or default CloudFront domain
AWS_CLOUDFRONT_DOMAIN=images.anyrent.shop

# Railway Volume (Fallback)
# Images are stored in Railway Volume (/app/public/uploads)
# 100GB free storage included with Railway plan

# ========================================
# LOGGING CONFIGURATION (Optional)
# ========================================
LOG_LEVEL=info
LOG_FORMAT=json

# ========================================
# RATE LIMITING (Optional)
# ========================================
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX=100

# ========================================
# EMAIL CONFIGURATION (AWS SES)
# ========================================
# Email Provider: 'console' (dev), 'ses' (AWS - production)
EMAIL_PROVIDER=ses
EMAIL_FROM=noreply@anyrent.shop

# AWS SES Configuration (uses same AWS credentials as S3)
# After verifying domain anyrent.shop in SES, you can send from any email in that domain
# Region must match the region where you verified the domain in AWS SES
AWS_SES_REGION=ap-southeast-1
# Uses existing: AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY (from S3 config above)

# ========================================
# IMAGE SEARCH - QDRANT VECTOR DATABASE
# ========================================
# Qdrant Configuration

# Local Development (Docker)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=  # Optional, only needed for Qdrant Cloud

# Railway Development / Production (Qdrant Cloud)
# QDRANT_URL=https://your-cluster-id.region.cloud.qdrant.io
# QDRANT_API_KEY=your-api-key-here
# Example:
# QDRANT_URL=https://6b2f953d-75c4-4ce5-bc1d-a479bfc4a397.europe-west3-0.gcp.cloud.qdrant.io
# QDRANT_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJhY2Nlc3MiOiJtIn0.rUuiTtqvpzKWQIbFV6IoL4wmw2Is_6lVy3A8t7OqEVo

# Collection Name Control (REQUIRED)
# QDRANT_COLLECTION_ENV must be set explicitly to determine which collection to use:
#   - Development: QDRANT_COLLECTION_ENV=development → uses product-images-dev
#   - Production: QDRANT_COLLECTION_ENV=production → uses product-images-pro
# 
# This is REQUIRED - the application will throw an error if not set.
# 
# Example for Railway:
#   Dev server: QDRANT_COLLECTION_ENV=development
#   Prod server: QDRANT_COLLECTION_ENV=production
QDRANT_COLLECTION_ENV=development

# Python Embedding Service (REQUIRED for embedding generation)
# Python embedding service is the default (USE_PYTHON_EMBEDDING_API defaults to true)
# This avoids Node.js memory issues and is the recommended approach
# Only set USE_PYTHON_EMBEDDING_API=false if you want to disable it (not recommended)

# Python Embedding API URL (REQUIRED)
# This should point to your Python embedding service (e.g., Railway deployment)
# Example: https://python-embedding-service-production.up.railway.app
PYTHON_EMBEDDING_API_URL=https://your-python-embedding-service.up.railway.app

# Model Configuration
IMAGE_SEARCH_MODEL=Xenova/clip-vit-base-patch32  # CLIP model (tương thích 100% với @xenova/transformers)
# Alternative: patrickjohncyh/fashion-clip (fashion-specific, cần test compatibility)
IMAGE_SEARCH_MIN_SIMILARITY=0.7            # Minimum similarity threshold (0.0-1.0)

# ========================================
# ANALYTICS & TRACKING
# ========================================
# Google Analytics 4 Measurement ID (for client-side tracking)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Search Console Verification Code
NEXT_PUBLIC_GOOGLE_VERIFICATION=your-google-verification-code

# Google Sign-In (OAuth Web Client ID)
# - apps/api: verify ID tokens (audience must match)
GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com
# - apps/client: Google button / One Tap (public; never put client secret here)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com

# Other Search Engine Verifications (Optional)
NEXT_PUBLIC_YANDEX_VERIFICATION=
NEXT_PUBLIC_YAHOO_VERIFICATION=

# ========================================
# FEATURE FLAGS (Optional)
# ========================================
ENABLE_EMAIL_VERIFICATION=true
ENABLE_ANALYTICS=false
ENABLE_DEBUG_LOGS=false

# ========================================
# LOCAL DEVELOPMENT ONLY
# ========================================
# For local development, use SQLite
# DATABASE_URL=file:./prisma/dev.db
# NODE_ENV=development
# JWT_SECRET=local-jwt-secret-DO-NOT-USE-IN-PRODUCTION
# NEXTAUTH_SECRET=local-nextauth-secret-DO-NOT-USE-IN-PRODUCTION
# API_URL=http://localhost:3002
# CLIENT_URL=http://localhost:3000
# ADMIN_URL=http://localhost:3001

# ========================================
# QUICK SETUP
# ========================================
# Use the automated setup script:
#   ./scripts/setup-railway-env.sh
#
# This will:
#   1. Generate secure secrets
#   2. Set all environment variables
#   3. Push database schema
#   4. Seed initial data
